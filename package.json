{
  "name": "google-sheets-editing-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server + CLI for editing Google Sheets via a service account fetched from 1Password.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hdanirwin/google-sheets-editing-mcp.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "start:mcp": "node dist/mcp/server.js",
    "start:cli": "node dist/cli/update-sheet.js",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "bin": {
    "google-sheets-mcp": "bin/google-sheets-mcp",
    "update-sheet": "bin/update-sheet"
  },
  "dependencies": {
    "@1password/sdk": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "googleapis": "^144.0.0",
    "papaparse": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.3.15",
    "typescript": "^5.7.2"
  }
}
