# Credentials — pick ONE of the two paths below.
#
# Option A: SA JSON on disk. Simplest if you already manage the file via
# Secret Manager, Vault, encrypted disk, etc. Takes precedence if both are set.
SHEETS_SA_JSON_PATH=

# Option B: 1Password secret reference. Used if SHEETS_SA_JSON_PATH is unset.
# Format: op://<vault>/<item>/<field-or-filename>
# Example: op://API Keys/my-gcp-sa/service-account.json
SHEETS_SA_OP_REF=

# 1Password service-account token (only needed if you use SHEETS_SA_OP_REF).
# Alternatively, place the token at ~/.config/1password/service-account-token
# with mode 600 and leave this empty.
OP_SERVICE_ACCOUNT_TOKEN=
